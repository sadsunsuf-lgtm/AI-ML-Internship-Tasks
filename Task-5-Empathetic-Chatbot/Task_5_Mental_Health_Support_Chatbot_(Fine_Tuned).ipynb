  "cells": [
    {
      "cell_type": "markdown",
      "source": [
        "Objective:\n",
        "\n",
        "Build a basic chatbot that provides supportive and empathetic responses for stress, anxiety,\n",
        "and emotional wellness."
      ],
      "metadata": {
        "id": "Mgoo-JpigBH2"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "Install important Libraries"
      ],
      "metadata": {
        "id": "6sZ9isgigF4c"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "!pip install -q transformers[torch] datasets accelerate peft bitsandbytes"
      ],
      "metadata": {
        "id": "cqr3TN2NgQ3V"
      },
      "execution_count": 1,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Load Dataset"
      ],
      "metadata": {
        "id": "-fADbnF1ghvD"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from datasets import load_dataset\n",
        "\n",
        "# Loading the Parquet version of the dataset (the new standard)\n",
        "dataset = load_dataset(\"Ahren09/empathetic_dialogues\")\n",
        "\n",
        "# Inspect the dataset structure\n",
        "print(f\"Dataset Structure: {dataset}\")\n",
        "\n",
        "# Let's show a sample to confirm the content\n",
        "sample = dataset['train'][0]\n",
        "print(\"\\n--- Sample Empathetic Dialogue ---\")\n",
        "print(f\"Context/Situation: {sample['prompt']}\")\n",
        "print(f\"Empathetic Response: {sample['utterance']}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "dnCEpkK2geUy",
        "outputId": "a1c9b7dc-7fbf-4778-c34f-7132a0aaa686"
      },
      "execution_count": 2,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stderr",
          "text": [
            "/usr/local/lib/python3.12/dist-packages/huggingface_hub/utils/_auth.py:94: UserWarning: \n",
            "The secret `HF_TOKEN` does not exist in your Colab secrets.\n",
            "To authenticate with the Hugging Face Hub, create a token in your settings tab (https://huggingface.co/settings/tokens), set it as secret in your Google Colab and restart your session.\n",
            "You will be able to reuse this secret in all of your notebooks.\n",
            "Please note that authentication is recommended but still optional to access public models or datasets.\n",
            "  warnings.warn(\n",
            "Warning: You are sending unauthenticated requests to the HF Hub. Please set a HF_TOKEN to enable higher rate limits and faster downloads.\n",
            "WARNING:huggingface_hub.utils._http:Warning: You are sending unauthenticated requests to the HF Hub. Please set a HF_TOKEN to enable higher rate limits and faster downloads.\n"
          ]
        },
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Dataset Structure: DatasetDict({\n",
            "    train: Dataset({\n",
            "        features: ['conv_id', 'utterance_idx', 'context', 'prompt', 'speaker_idx', 'utterance', 'selfeval', 'tags'],\n",
            "        num_rows: 84169\n",
            "    })\n",
            "    validation: Dataset({\n",
            "        features: ['conv_id', 'utterance_idx', 'context', 'prompt', 'speaker_idx', 'utterance', 'selfeval', 'tags'],\n",
            "        num_rows: 6340\n",
            "    })\n",
            "    test: Dataset({\n",
            "        features: ['conv_id', 'utterance_idx', 'context', 'prompt', 'speaker_idx', 'utterance', 'selfeval', 'tags'],\n",
            "        num_rows: 5714\n",
            "    })\n",
            "})\n",
            "\n",
            "--- Sample Empathetic Dialogue ---\n",
            "Context/Situation: I remember going to the fireworks with my best friend. There was a lot of people_comma_ but it only felt like us in the world.\n",
            "Empathetic Response: I remember going to see the fireworks with my best friend. It was the first time we ever spent time alone together. Although there was a lot of people_comma_ we felt like the only people in the world.\n"
          ]
        }
      ]
    },
